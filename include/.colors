# COLORS

# taken from URL:
# https://misc.flogisoft.com/bash/tip_colors_and_formatting

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# RESET
RESET_ALL="\e[0m"
RESET_BOLD_BRIGHT="\e[21m"
RESET_DIM="\e[22"
RESET_UNDERLINE="\e[24m"
RESET_BLINK="\e[25m"
RESET_INVERTED="\e[27m"
RESET_HIDDEN="\e[28m"

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# SET
FONT_BOLD="\e[1m"
FONT_DIM="\e[2m"
FONT_UNDERLINE="\e[4m"
FONT_BLINK="\e[5m"
FONT_INVERTED="\e[7m"
FONT_HIDDEN="\e[8m"

# ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# FOREGROUND
